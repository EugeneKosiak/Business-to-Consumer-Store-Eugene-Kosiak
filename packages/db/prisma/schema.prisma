generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id          Int      @id @default(autoincrement())
  urlId       String   @unique
  title       String
  category    String
  description String
  content     String
  tags        String
  imageUrl    String
  active      Boolean  @default(true)
  date        DateTime @default(now())
  views       Int      @default(0)
  likes       Like[]
}

model Like {
  postId Int
  userIP String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, userIP])
}
